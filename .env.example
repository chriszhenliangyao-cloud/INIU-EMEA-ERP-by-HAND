NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# PO import (Shipment Workflow → Import PO). Free-tier Google Gemini key.
# Get one at https://aistudio.google.com/apikey  ·  add the same key in Vercel → Settings → Environment Variables
GEMINI_API_KEY=
# optional override, default gemini-2.0-flash
GEMINI_MODEL=
